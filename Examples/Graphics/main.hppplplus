#pragma mode( separator(.,;) integer(h64) indentation(2) )
{$ADDON grob.bmp}
USES HP;
ALIAS spectrum := s;
LOCAL spectrum := {$INCLUDE spectrum.bmp};

EXPORT START()
BEGIN
  RECT();
  HP.IMAGE(G0, 0, 0, spectrum);
  WAIT(-1);
  RETURN 0;
END;
REGEX `\bloop\b`i WHILE 1 DO
EXPORT RESET()
BEGIN
  LOOP
  END;
  RETURN 0;
END;
