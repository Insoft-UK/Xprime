#pragma mode( separator(.,;) integer(h64) )

{$ADDON hpfont.h}

uses HP;

var CGA := {$I CGA.h};

alias WHITE := #FFFFFF:32h;
alias BLACK := 0;

export START()
begin
	RECT(BLACK);
	HP.TEXTOUT("CGA Font Example", G0, 0, 0, CGA, WHITE);
	WAIT(-1);
    return 0;
end;

export RESET()
begin
    return 0;
end;
