#pragma mode( separator(.,;) integer(h64) )

{$ADDON hpfont.h}

uses HP;

var CGA := {$I CGA.h};

dictionary White := #FFFFFF:32h, Black  := 0 Color;

export START()
begin
	RECT(Color.Black);
	HP.TEXTOUT("CGA Font Example", G0, 0, 0, CGA, Color.White, 1);
	WAIT(-1);
    return 0;
end;

export RESET()
begin
    return 0;
end;
