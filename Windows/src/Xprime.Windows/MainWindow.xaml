<Window x:Class="Xprime.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="Xprime for Windows" Height="820" Width="1240" MinHeight="680" MinWidth="980"
        Loaded="Window_Loaded">
    <DockPanel Background="#1F2329">
        <Menu DockPanel.Dock="Top" Background="#2D333B" Foreground="#F0F3F6">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Project..." Click="OpenProject_Click" />
                <MenuItem Header="_Save Source" Click="SaveSource_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Build">
                <MenuItem Header="Build _Program" Click="BuildProgram_Click" />
                <MenuItem Header="Build _Application" Click="BuildApplication_Click" />
                <MenuItem Header="_Archive Application" Click="ArchiveApplication_Click" />
            </MenuItem>
        </Menu>

        <Grid DockPanel.Dock="Top" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ProjectPathBox" Height="30" VerticalContentAlignment="Center"
                     Background="#0D1117" Foreground="#F0F3F6" BorderBrush="#444C56"
                     ToolTip="Current .xprimeproj path" />
            <Button Grid.Column="1" Margin="8,0,0,0" Padding="12,4" Content="Open" Click="OpenProject_Click" />
            <Button Grid.Column="2" Margin="8,0,0,0" Padding="12,4" Content="Save" Click="SaveSource_Click" />
            <ComboBox x:Name="ThemeBox" Grid.Column="3" Margin="8,0,0,0" Width="160" DisplayMemberPath="Name" SelectionChanged="ThemeBox_SelectionChanged" />
            <CheckBox x:Name="PerformInstallBox" Grid.Column="4" Margin="10,0,0,0"
                      VerticalAlignment="Center" Foreground="#F0F3F6"
                      Content="Perform install" ToolTip="Unchecked means install buttons only dry-run the copy plan." />
        </Grid>

        <Grid Margin="12,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="170" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" BorderBrush="#444C56" BorderThickness="1" Background="#22272E">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="10" FontWeight="SemiBold" Foreground="#F0F3F6" Text="Project Files" />
                    <ListBox x:Name="FileList" Background="#22272E" Foreground="#F0F3F6" BorderThickness="0"
                             SelectionChanged="FileList_SelectionChanged" />
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="8,0" BorderBrush="#444C56" BorderThickness="1">
                <avalon:TextEditor x:Name="Editor"
                                   FontFamily="Cascadia Mono, Consolas"
                                   FontSize="14"
                                   ShowLineNumbers="True"
                                   WordWrap="False" />
            </Border>

            <Border Grid.Row="0" Grid.Column="2" BorderBrush="#444C56" BorderThickness="1" Background="#22272E">
                <TabControl x:Name="RightTabs" Background="#22272E" Foreground="#F0F3F6" BorderThickness="0">
                    <TabItem Header="Build">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <TextBlock FontWeight="SemiBold" Foreground="#F0F3F6" Text="Workflows" />
                                <Button Margin="0,10,0,0" Padding="10,7" Content="Build Program (.hpprgm)" Click="BuildProgram_Click" />
                                <Button Margin="0,8,0,0" Padding="10,7" Content="Build App (.hpappdir)" Click="BuildApplication_Click" />
                                <Button Margin="0,8,0,0" Padding="10,7" Content="Archive App (.zip)" Click="ArchiveApplication_Click" />
                                <Separator Margin="0,12,0,12" />
                                <TextBlock Foreground="#ADBAC7" Text="Calculator" />
                                <ComboBox x:Name="CalculatorBox" Margin="0,4,0,0" IsEditable="True" />
                                <Button Margin="0,8,0,0" Padding="10,7" Content="Install Program" Click="InstallProgram_Click" />
                                <Button Margin="0,8,0,0" Padding="10,7" Content="Install App Directory" Click="InstallApplication_Click" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Project">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <CheckBox x:Name="CompressionBox" Foreground="#F0F3F6" Content="Compress output" />
                                <CheckBox x:Name="ArchiveProjectAppOnlyBox" Margin="0,6,0,0" Foreground="#F0F3F6" Content="Archive project app only" />
                                <TextBlock Margin="0,10,0,0" Foreground="#ADBAC7" Text="Language" />
                                <ComboBox x:Name="LanguageBox" Margin="0,4,0,0" IsEditable="True">
                                    <ComboBoxItem Content="hppplplus" />
                                    <ComboBoxItem Content="hpppl" />
                                    <ComboBoxItem Content="pas" />
                                    <ComboBoxItem Content="prgm" />
                                </ComboBox>
                                <TextBlock Margin="0,10,0,0" Foreground="#ADBAC7" Text="Base app" />
                                <ComboBox x:Name="BaseApplicationBox" Margin="0,4,0,0" IsEditable="False" />
                                <TextBlock Margin="0,10,0,0" Foreground="#ADBAC7" Text="Include" />
                                <TextBox x:Name="IncludeBox" Margin="0,4,0,0" Background="#0D1117" Foreground="#F0F3F6" BorderBrush="#444C56" />
                                <TextBlock Margin="0,10,0,0" Foreground="#ADBAC7" Text="Lib" />
                                <TextBox x:Name="LibBox" Margin="0,4,0,0" Background="#0D1117" Foreground="#F0F3F6" BorderBrush="#444C56" />
                                <TextBlock Margin="0,10,0,0" Foreground="#ADBAC7" Text="Bin" />
                                <TextBox x:Name="BinBox" Margin="0,4,0,0" Background="#0D1117" Foreground="#F0F3F6" BorderBrush="#444C56" />
                                <Button Margin="0,12,0,0" Padding="10,7" Content="Save Project Settings" Click="SaveProjectSettings_Click" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Help">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="170" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBox x:Name="HelpSearchBox" Height="28" VerticalContentAlignment="Center"
                                     Background="#0D1117" Foreground="#F0F3F6" BorderBrush="#444C56"
                                     TextChanged="HelpSearchBox_TextChanged" />
                            <ListBox x:Name="HelpTopicList" Grid.Row="1" Margin="0,8,0,8"
                                     Background="#22272E" Foreground="#F0F3F6" BorderBrush="#444C56"
                                     DisplayMemberPath="Title" SelectionChanged="HelpTopicList_SelectionChanged" />
                            <TextBox x:Name="HelpViewer" Grid.Row="2" Background="#0D1117" Foreground="#ADBAC7"
                                     BorderBrush="#444C56" IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="Snippets">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ListBox x:Name="SnippetList" Background="#22272E" Foreground="#F0F3F6" BorderBrush="#444C56"
                                     DisplayMemberPath="Title" SelectionChanged="SnippetList_SelectionChanged" />
                            <TextBox x:Name="SnippetDescription" Grid.Row="1" Margin="0,8,0,8"
                                     Background="#0D1117" Foreground="#ADBAC7" BorderBrush="#444C56"
                                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                            <Button Grid.Row="2" Padding="10,7" Content="Insert Snippet" Click="InsertSnippet_Click" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0" BorderBrush="#444C56" BorderThickness="1" Background="#0D1117">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="10,8,10,0" FontWeight="SemiBold" Foreground="#F0F3F6" Text="Output" />
                    <TextBox x:Name="OutputBox" Margin="10" Background="#0D1117" Foreground="#ADBAC7"
                             BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
