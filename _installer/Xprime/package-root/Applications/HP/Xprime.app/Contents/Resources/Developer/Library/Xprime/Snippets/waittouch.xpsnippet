{
    "title": "Wait for Touch",
    "body": [
      "LOCAL f1, f2;",
      "REPEAT",
      "  WAIT(0.1);",
      "  {f1, f2} := MOUSE;",
      "UNTIL SIZE(f1) > 0 AND f1(1) >= 0;",
      "LOCAL ${1:tx} := f1(1), ${2:ty} := f1(2);",
      "$0"
    ],
    "description": "Block until user touches the screen, then get coordinates"
}
