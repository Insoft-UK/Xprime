{
    "title": "CHOOSE Dialog",
        "body": [
      "LOCAL ${1:choice} := 0;",
      "IF CHOOSE(${1:choice}, \"${2:Select}\", \"${3:Option 1}\", \"${4:Option 2}\", \"${5:Option 3}\") THEN",
      "  CASE",
      "    IF ${1:choice} == 1 THEN $0 END;",
      "    IF ${1:choice} == 2 THEN  END;",
      "    IF ${1:choice} == 3 THEN  END;",
      "  END;",
      "END;"
    ],
    "description": "CHOOSE dialog with CASE dispatch (1-based index)"
}
