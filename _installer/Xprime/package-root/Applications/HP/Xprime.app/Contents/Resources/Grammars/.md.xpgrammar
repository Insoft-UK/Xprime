{
    "name": "Markdown",
    "scopeName": "source.md",
    "patterns": [
        {
            "name": "Symbols",
            "match": "[*#-]+"
        },
        {
            "name": "Brackets",
            "match": "[{}]+"
        },
        {
            "name": "Backquotes",
            "match": "`.*?`"
        },
        {
            "name": "Strings",
            "match": "\"([^\"\\\\]|\\\\.)*\""
        }
    ]
}
