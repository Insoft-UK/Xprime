{
    "title": "Key Dispatch",
    "body": [
      "LOCAL key := GETKEY;",
      "CASE",
      "  IF key == 4  THEN ${1:// ESC} END;",
      "  IF key == 30 THEN ${2:// Enter} END;",
      "  IF key == 2  THEN ${3:// Up} END;",
      "  IF key == 12 THEN ${4:// Down} END;",
      "  IF key == 7  THEN ${5:// Left} END;",
      "  IF key == 8  THEN ${6:// Right} END;",
      "  DEFAULT $0;",
      "END;"
    ],
    "description": "GETKEY + CASE for common navigation keys"
}
