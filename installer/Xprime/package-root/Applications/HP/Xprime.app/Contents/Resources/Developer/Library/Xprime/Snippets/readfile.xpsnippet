{
    "title": "Read File",
    "body": [
      "LOCAL ${1:f} := OPEN(\"${2:filename}\");",
      "LOCAL ${3:content} := \"\";",
      "WHILE NOT EOF(${1:f}) DO",
      "  ${3:content} := ${3:content} + READLINE(${1:f});",
      "END;",
      "CLOSE(${1:f});",
      "$0"
    ],
    "description": "Open a file, read all lines, and close it"
}


