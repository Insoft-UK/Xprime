{
    "title": "Event Loop (WHILE)",
    "body": [
      "LOCAL key := 0, f1, f2;",
      "WHILE key ≠ 4 DO",
      "  WAIT(${1:0.05});",
      "  key := GETKEY;",
      "  {f1, f2} := MOUSE;",
      "  IF SIZE(f1) > 0 AND f1(1) >= 0 THEN",
      "    $0",
      "  END;",
      "END;"
    ],
    "description": "WHILE event loop — runs until ESC pressed"
}

