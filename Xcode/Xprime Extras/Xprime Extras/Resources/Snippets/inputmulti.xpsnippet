{
    "title": "INPUT Dialog (Multi-Field)",
    "body": [
      "LOCAL ${1:A} := ${2:0};",
      "LOCAL ${3:B} := ${4:0};",
      "IF INPUT({${1:A}, ${3:B}}, \"${5:Parameters}\", {\"${6:Field 1:}\", \"${7:Field 2:}\"}, {\"${8:Help 1}\", \"${9:Help 2}\"}) THEN",
      "  $0",
      "END;"
    ],
    "description": "Multi-field INPUT dialog with variable lists"
}
