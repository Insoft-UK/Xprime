{
    "title": "Python Block",
    "body": [
      "#PYTHON ${1:MyPython}",
      "  import hpprime as h",
      "  $0",
      "#END",
      "",
      "EXPORT ${2:RunPython}()",
      "BEGIN",
      "  PYTHON(${1:MyPython});",
      "END;"
    ],
    "description": "Inline Python block with PPL wrapper function"
}
