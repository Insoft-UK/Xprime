{
    "title": "Scroll Content Up",
    "body": [
      "// Scroll content area up by ${1:20} pixels",
      "STRBLIT(G0, 0, ${2:21}, 320, ${3:199}, G0, 0, ${2:21}+${1:20}, 320, ${3:199});",
      "// Clear newly exposed area",
      "RECT_P(G0, 0, ${3:199}, 319, ${3:199}+${1:20}, #FFFFFFh, #FFFFFFh);",
      "$0"
    ],
    "description": "Scroll a screen region up using STRBLIT and clear the bottom"
}
